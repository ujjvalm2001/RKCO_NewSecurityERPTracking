                                    <i class="ri-dashboard-2-line"></i><span data-key="t-dashboards">Registration</span>
                                </a>
                                <div class="collapse menu-dropdown" id="sidebarRegistration">
                                    <ul class="nav nav-sm flex-column">
                                        <li class="nav-item">
